{
  "name": "antigravity-auth",
  "version": "1.9.0",
  "description": "Google Antigravity provider for OpenCode and Claude Code, built on core-auth — multi-account rotation, quota management, proxy support",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "antigravity": "dist/cli.js"
  },
  "license": "MIT",
  "author": "intisy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/intisy-ai/antigravity-auth.git"
  },
  "keywords": [
    "opencode",
    "claude",
    "antigravity",
    "google",
    "oauth",
    "gemini",
    "core-auth",
    "provider"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "claudeHub": {
    "authProviders": [
      {
        "name": "antigravity",
        "handler": "dist/handler.js",
        "models": []
      }
    ]
  },
  "scripts": {
    "build": "npx tsc --project core-auth/tsconfig.json && node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@openauthjs/openauth": "^0.4.3",
    "@opencode-ai/plugin": "^0.15.30",
    "proper-lockfile": "^4.1.2",
    "xdg-basedir": "^5.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/proper-lockfile": "^4.1.4",
    "esbuild": "^0.25.12",
    "typescript": "^5.0.0",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
